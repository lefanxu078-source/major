{
  "name": "live-screen-focus-monitor",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run build && concurrently -k -n server,web \"npm run server\" \"npm run preview\"",
    "build": "tsc -b && npm run server:check && vite build --config vite.config.js --configLoader runner",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "preview": "vite preview --config vite.config.js --configLoader runner --host 127.0.0.1",
    "server": "tsx server/index.ts",
    "server:check": "tsc --noEmit -p server/tsconfig.json"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sass": "^1.83.4",
    "typescript": "~5.7.2",
    "vite": "^6.0.7",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@rollup/plugin-typescript": "^12.1.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.3",
    "@types/react-dom": "^19.0.2",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "tslib": "^2.8.1",
    "tsx": "^4.20.3",
    "typescript-eslint": "^8.18.2"
  }
}
